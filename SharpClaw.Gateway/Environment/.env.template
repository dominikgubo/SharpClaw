{
  // SharpClaw Gateway Environment Configuration
  // Values here are loaded for all environments.

  // ── Internal API ───────────────────────────────────────────────
  // Base URL of the internal SharpClaw Application API.
  "InternalApi": { "BaseUrl": "http://127.0.0.1:48923" },

  // ── Endpoint Toggles ───────────────────────────────────────────

  // Set "Enabled" to false to disable the entire gateway.
  "Gateway": {
    "Endpoints": {
      "Enabled": "true",
      "Auth": "true",
      "Agents": "true",
      "Channels": "true",
      "ChannelContexts": "true",
      "Chat": "true",
      "ChatStream": "true",
      "Threads": "true",
      "ThreadChat": "true",
      "Jobs": "true",
      "Models": "true",
      "Providers": "true",
      "Roles": "true",
      "Users": "true",
      "AudioDevices": "true",
      "Transcription": "true",
      "TranscriptionStreaming": "true",
      "Cost": "true",
      "Bots": "true"
    },

    // ── Bot Integrations ─────────────────────────────────────────
    "Bots": {
      // Telegram bot — obtain a token from @BotFather.
      "Telegram": {
        "Enabled": "false",
        "BotToken": ""
      },
      // Discord bot — obtain a token from the Discord Developer Portal.
      "Discord": {
        "Enabled": "false",
        "BotToken": ""
      }
    }
  }
}
